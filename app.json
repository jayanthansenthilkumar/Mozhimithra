{
  "expo": {
    "name": "MozhiMithra",
    "slug": "mozhimithra",
    "version": "1.0.0",
    "extra": {
      "eas": {
        "projectId": "368660f0-5f84-4b59-b1a9-67541d8fb689"
      }
    },
    "orientation": "portrait",
    "icon": "./assets/images/Mozhimithra.png",
    "scheme": "mozhimithra",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mozhimithra.languageapp"
    },
    "android": {
      "package": "com.mozhimithra.languageapp",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/Mozhimithra.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false
    },
    "androidStatusBar": {
      "translucent": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Mozhimithra.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Mozhimithra.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
